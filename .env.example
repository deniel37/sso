# Copy to .env.local and fill in the values.

# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
AUTH_URL="http://localhost:3000"

# Microsoft Entra ID — from your Azure app registration
# (Azure Portal → App registrations → your app).
#
# Azure-portal prerequisites for sign-in to succeed (no code change needed):
#   1. Redirect URI (platform: Web):
#        http://localhost:3000/api/auth/callback/microsoft-entra-id
#      A mismatch causes AADSTS50011.
#   2. "Supported account types" must MATCH the authority below. For "common"
#      (any Microsoft account), choose:
#        "Accounts in any organizational directory (multitenant) and personal
#         Microsoft accounts".
#      A single-tenant registration paired with "common" causes
#      AADSTS50020 / AADSTS700016 for personal/external accounts.
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=

# Authority / audience:
#   common         → any Microsoft account (work, school, or personal)
#   <tenant-id>    → only that organization's accounts
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/common/v2.0"

# Facebook — from your Facebook app (developers.facebook.com → your app).
#
# Facebook-app prerequisites for sign-in to succeed (no code change needed):
#   1. Add the "Facebook Login" product → Settings → "Valid OAuth Redirect URIs":
#        http://localhost:3000/api/auth/callback/facebook
#   2. localhost only works while the app is in "Development" mode (or you are
#      added as a Tester). Production needs an HTTPS redirect URI and may require
#      App Review for the `email` permission.
# Facebook is OAuth2 (not OIDC), so there is no issuer/authority variable.
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=
